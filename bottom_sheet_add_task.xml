<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingHorizontal="20dp"
    android:paddingTop="8dp"
    android:paddingBottom="32dp">


    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/shape_drag_handle" />


    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Task"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:fontFamily="@font/inter_bold"
        android:layout_marginBottom="20dp" />


    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Task title *"
        app:boxBackgroundColor="@color/input_background"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusTopStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusBottomEnd="10dp"
        app:hintTextColor="@color/text_secondary"
        app:boxStrokeColor="@color/accent"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:fontFamily="@font/inter_regular" />

    </com.google.android.material.textfield.TextInputLayout>


    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Description (optional)"
        app:boxBackgroundColor="@color/input_background"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusTopStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusBottomEnd="10dp"
        app:hintTextColor="@color/text_secondary"
        app:boxStrokeColor="@color/accent"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="3"
            android:fontFamily="@font/inter_regular" />

    </com.google.android.material.textfield.TextInputLayout>

    
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickTime"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="⏰  Select Time"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="@font/inter_medium"
        app:backgroundTint="@color/input_background"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp"
        app:cornerRadius="10dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Priority"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="@font/inter_medium"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp" />

    <RadioGroup
        android:id="@+id/rgPriority"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:checkedButton="@id/rbMedium">

        <RadioButton
            android:id="@+id/rbLow"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Low"
            android:gravity="center"
            android:textColor="@color/priority_low"
            android:buttonTint="@color/priority_low"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:background="@drawable/bg_priority_option"
            android:layout_marginEnd="6dp" />

        <RadioButton
            android:id="@+id/rbMedium"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Medium"
            android:gravity="center"
            android:textColor="@color/priority_medium"
            android:buttonTint="@color/priority_medium"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:background="@drawable/bg_priority_option"
            android:layout_marginHorizontal="3dp" />

        <RadioButton
            android:id="@+id/rbHigh"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="High"
            android:gravity="center"
            android:textColor="@color/priority_high"
            android:buttonTint="@color/priority_high"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:background="@drawable/bg_priority_option"
            android:layout_marginStart="6dp" />

    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveTask"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="Save Task"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:fontFamily="@font/inter_semibold"
        app:backgroundTint="@color/accent"
        app:cornerRadius="12dp" />

</LinearLayout>
   
